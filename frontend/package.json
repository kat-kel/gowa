{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --runInBand",
    "test-ci": "jest --runInBand --forceExit --ci --detectOpenHandles",
    "test:e2e": "docker compose --profile test up frontend-test --abort-on-container-exit",
    "test:e2e:down": "docker compose --profile test down"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "next": "16.1.6",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "jest": "^29",
    "ts-jest": "^29",
    "@types/jest": "^29"
  }
}
